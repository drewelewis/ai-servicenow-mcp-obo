# ServiceNow MCP Server Environment Variables

# ServiceNow Instance URL
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com/

# Authentication - Basic Auth
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password

# Authentication - Token Auth (alternative to Basic Auth)
# SERVICENOW_TOKEN=your-token

# Authentication - OAuth (alternative to Basic Auth)
# SERVICENOW_CLIENT_ID=your-client-id
# SERVICENOW_CLIENT_SECRET=your-client-secret
# SERVICENOW_USERNAME=your-username
# SERVICENOW_PASSWORD=your-password

# Authentication - Entra OBO (alternative to Basic/Token/OAuth)
# SERVICENOW_OBO_TENANT_ID=your-tenant-id
# SERVICENOW_OBO_CLIENT_ID=your-app-client-id
# SERVICENOW_OBO_CLIENT_SECRET=your-app-client-secret
# SERVICENOW_OBO_USER_ASSERTION=incoming-user-access-token
# Optional local testing fallback only (not for production)
# SERVICENOW_OBO_ALLOW_STATIC_ASSERTION=false
# SERVICENOW_OBO_SCOPE=api://your-downstream-app-id/.default
# Optional local interactive sign-in settings (for helper script only)
# SERVICENOW_OBO_PUBLIC_CLIENT_ID=your-public-client-id
# SERVICENOW_OBO_USER_SCOPE=api://your-broker-app-id/user_impersonation
# SERVICENOW_OBO_ALLOW_DEVICE_CODE_FALLBACK=true
# Optional: comma-separated expected audiences for incoming bearer tokens
# SERVICENOW_OBO_EXPECTED_AUDIENCE=your-app-client-id,api://your-app-client-id
# Optional: comma-separated allowed issuers for incoming bearer tokens
# SERVICENOW_OBO_EXPECTED_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# Optional: override token endpoint
# SERVICENOW_OBO_TOKEN_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token

# Authentication - ServiceNow OAuth JWT Bearer (recommended delegated user pattern)
# Validates incoming Entra user token, then exchanges a signed JWT assertion at ServiceNow.
# SERVICENOW_SN_JWT_TENANT_ID=your-tenant-id
# SERVICENOW_SN_JWT_UPSTREAM_CLIENT_ID=your-broker-app-client-id
# SERVICENOW_SN_JWT_CLIENT_ID=your-servicenow-oauth-client-id
# Provide one of the following private-key inputs:
# SERVICENOW_SN_JWT_PRIVATE_KEY_PATH=C:/path/to/private_key.pem
# SERVICENOW_SN_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Optional: passphrase if key is encrypted
# SERVICENOW_SN_JWT_PRIVATE_KEY_PASSPHRASE=your-passphrase
# Optional: include if ServiceNow OAuth app requires a client secret
# SERVICENOW_SN_JWT_CLIENT_SECRET=your-servicenow-oauth-client-secret
# Optional: explicit OAuth scope for the token endpoint
# SERVICENOW_SN_JWT_SCOPE=useraccount
# Optional: JWT header key id
# SERVICENOW_SN_JWT_KID=your-key-id
# Optional: defaults to <instance>/oauth_token.do
# SERVICENOW_SN_JWT_TOKEN_ENDPOINT=https://your-instance.service-now.com/oauth_token.do
# Optional: choose subject claim mapped to ServiceNow user (default preferred_username)
# SERVICENOW_SN_JWT_USER_CLAIM_SOURCE=preferred_username
# Optional local testing fallback only (not for production)
# SERVICENOW_SN_JWT_USER_ASSERTION=incoming-user-access-token
# SERVICENOW_SN_JWT_ALLOW_STATIC_ASSERTION=false
# Optional: comma-separated expected audiences for incoming bearer tokens
# SERVICENOW_SN_JWT_EXPECTED_AUDIENCE=your-broker-app-client-id,api://your-broker-app-client-id
# Optional: comma-separated allowed issuers for incoming bearer tokens
# SERVICENOW_SN_JWT_EXPECTED_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# Optional tuning
# SERVICENOW_SN_JWT_ASSERTION_TTL=300
# SERVICENOW_SN_JWT_CACHE_SAFETY_BUFFER=60
