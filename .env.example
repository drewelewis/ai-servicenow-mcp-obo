# ServiceNow MCP Server Environment Variables

# ServiceNow Instance URL
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com/

# Authentication - Basic Auth
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password

# Authentication - Token Auth (alternative to Basic Auth)
# SERVICENOW_TOKEN=your-token

# Authentication - OAuth (alternative to Basic Auth)
# SERVICENOW_CLIENT_ID=your-client-id
# SERVICENOW_CLIENT_SECRET=your-client-secret
# SERVICENOW_USERNAME=your-username
# SERVICENOW_PASSWORD=your-password

# Authentication - Entra OBO (alternative to Basic/Token/OAuth)
# SERVICENOW_OBO_TENANT_ID=your-tenant-id
# SERVICENOW_OBO_CLIENT_ID=your-app-client-id
# SERVICENOW_OBO_CLIENT_SECRET=your-app-client-secret
# SERVICENOW_OBO_USER_ASSERTION=incoming-user-access-token
# Optional local testing fallback only (not for production)
# SERVICENOW_OBO_ALLOW_STATIC_ASSERTION=false
# SERVICENOW_OBO_SCOPE=api://your-downstream-app-id/.default
# Optional: comma-separated expected audiences for incoming bearer tokens
# SERVICENOW_OBO_EXPECTED_AUDIENCE=your-app-client-id,api://your-app-client-id
# Optional: comma-separated allowed issuers for incoming bearer tokens
# SERVICENOW_OBO_EXPECTED_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# Optional: override token endpoint
# SERVICENOW_OBO_TOKEN_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
